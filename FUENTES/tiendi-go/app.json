{
  "expo": {
    "name": "Tiendi Go",
    "slug": "tiendi-go",
    "version": "1.0.0",
    "scheme": "tiendigo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tiendi.go",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Tiendi Go necesita tu ubicación para asignarte pedidos y mostrar tu posición a la tienda y al cliente durante la entrega.",
        "NSLocationAlwaysUsageDescription": "Tiendi Go rastrea tu ubicación en segundo plano mientras estés Online para que puedas recibir pedidos.",
        "NSLocationWhenInUseUsageDescription": "Tiendi Go usa tu ubicación para mostrarte pedidos cercanos.",
        "NSCameraUsageDescription": "Tiendi Go usa la cámara para escanear QR, fotografiar documentos y registrar la prueba de entrega.",
        "NSMicrophoneUsageDescription": "Tiendi Go puede necesitar el micrófono durante llamadas de soporte."
      }
    },
    "android": {
      "package": "com.tiendi.go",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#F97316",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDHk3r2823tPzYW6wC9X8v_raDC7h6g3qY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tiendi Go necesita tu ubicación para asignarte pedidos y mostrar tu posición durante la entrega.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tiendi Go usa la cámara para escanear QR, fotografiar documentos y registrar la prueba de entrega."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F97316",
          "defaultChannel": "default",
          "sounds": [
            "./assets/sounds/offer.wav"
          ],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Tiendi Go usa Face ID para que puedas iniciar sesión rápidamente."
        }
      ],
      "react-native-maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3d4dc245-6ab9-4853-be82-09a29a49485c"
      }
    },
    "owner": "tiendi"
  }
}
